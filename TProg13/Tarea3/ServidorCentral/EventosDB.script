ALTER USER SA SET LOCAL TRUE
CREATE SCHEMA PUBLIC AUTHORIZATION DBA
SET SCHEMA PUBLIC
CREATE MEMORY TABLE PUBLIC.USUARIOS(NICKNAME VARCHAR(50) NOT NULL PRIMARY KEY,DTYPE VARCHAR(31),CONTRASENA VARCHAR(255) NOT NULL,EMAIL VARCHAR(120) NOT NULL,IMAGEN VARCHAR(255),NOMBRE VARCHAR(100) NOT NULL,CONSTRAINT UK_USUARIOS_EMAIL UNIQUE(EMAIL))
CREATE MEMORY TABLE PUBLIC.ORGANIZADORES(NICKNAME VARCHAR(50) NOT NULL PRIMARY KEY,DESCRIPCION VARCHAR(500),LINK VARCHAR(255),CONSTRAINT FK_ORGANIZADORES_NICKNAME FOREIGN KEY(NICKNAME) REFERENCES PUBLIC.USUARIOS(NICKNAME))
CREATE MEMORY TABLE PUBLIC.EDICIONES(NOMBRE VARCHAR(200) NOT NULL PRIMARY KEY,CIUDAD VARCHAR(100),ESTADO VARCHAR(50),EVENTO VARCHAR(200),FECHA_ALTA DATE,FECHA_FIN DATE,FECHA_INICIO DATE,IMAGEN VARCHAR(255),PAIS VARCHAR(100),SIGLA VARCHAR(50),VIDEO VARCHAR(255),ORGANIZADOR_NICK VARCHAR(50),CONSTRAINT FK_EDICIONES_ORGANIZADOR_NICK FOREIGN KEY(ORGANIZADOR_NICK) REFERENCES PUBLIC.USUARIOS(NICKNAME))
CREATE MEMORY TABLE PUBLIC.REGISTROS(IDENTIFICADOR VARCHAR(100) NOT NULL PRIMARY KEY,ASISTENCIA_MARCADA BOOLEAN,COSTO DOUBLE,EVENTO VARCHAR(120),FECHA_INICIO DATE,FECHA_REGISTRO DATE,TIPO_REGISTRO VARCHAR(100),EDICION_NOMBRE VARCHAR(200),USUARIO_NICK VARCHAR(50),CONSTRAINT FK_REGISTROS_USUARIO_NICK FOREIGN KEY(USUARIO_NICK) REFERENCES PUBLIC.USUARIOS(NICKNAME),CONSTRAINT FK_REGISTROS_EDICION_NOMBRE FOREIGN KEY(EDICION_NOMBRE) REFERENCES PUBLIC.EDICIONES(NOMBRE))
CREATE MEMORY TABLE PUBLIC.ASISTENTES(NICKNAME VARCHAR(50) NOT NULL PRIMARY KEY,APELLIDO VARCHAR(100),FECHA_NACIMIENTO DATE,INSTITUCION VARCHAR(150),CONSTRAINT FK_ASISTENTES_NICKNAME FOREIGN KEY(NICKNAME) REFERENCES PUBLIC.USUARIOS(NICKNAME))
ALTER SEQUENCE SYSTEM_LOBS.LOB_ID RESTART WITH 1
SET DATABASE DEFAULT INITIAL SCHEMA PUBLIC
GRANT USAGE ON DOMAIN INFORMATION_SCHEMA.YES_OR_NO TO PUBLIC
GRANT USAGE ON DOMAIN INFORMATION_SCHEMA.TIME_STAMP TO PUBLIC
GRANT USAGE ON DOMAIN INFORMATION_SCHEMA.CARDINAL_NUMBER TO PUBLIC
GRANT USAGE ON DOMAIN INFORMATION_SCHEMA.CHARACTER_DATA TO PUBLIC
GRANT USAGE ON DOMAIN INFORMATION_SCHEMA.SQL_IDENTIFIER TO PUBLIC
GRANT DBA TO SA
SET SCHEMA SYSTEM_LOBS
